<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1.0.0" author="nastya.kharchenko">
        <createTable tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="username" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="first_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="last_name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>

            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="password" type="varchar(255)">
                <constraints nullable="false"/>
            </column>

            <column name="phone" type="varchar(20)">
                <constraints unique="true"/>
            </column>

            <column name="status" type="varchar(25)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>

            <column name="created" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>
    </changeSet>

    <changeSet id="1.0.1" author="nastya.kharchenko">
        <createTable tableName="roles">

            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>

            <column name="status" type="varchar(25)" defaultValue="ACTIVE">
                <constraints nullable="false"/>
            </column>

            <column name="created" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="1.0.2" author="nastya.kharchenko">
        <createTable tableName="user_roles">
            <column name="user_id" type="bigint">
            </column>

            <column name="role_id" type="bigint">
            </column>
        </createTable>
    </changeSet>

    <!-- Добавление внешних ключей -->
    <changeSet id="1.0.3" author="nastya.kharchenko">
        <addForeignKeyConstraint baseTableName="user_roles"
                                 baseColumnNames="user_id"
                                 constraintName="fk_user_roles_user"
                                 referencedTableName="users"
                                 referencedColumnNames="id"/>
    </changeSet>

    <changeSet id="1.0.4" author="nastya.kharchenko">
        <addForeignKeyConstraint baseTableName="user_roles"
                                 baseColumnNames="role_id"
                                 constraintName="fk_user_roles_roles"
                                 referencedTableName="roles"
                                 referencedColumnNames="id"/>
    </changeSet>

    <!-- Добавление ролей: админ и юзер -->
    <changeSet id="1.0.5" author="nastya.kharchenko">
        <insert tableName="roles">
            <column name="name" value="USER"></column>
        </insert>
    </changeSet>

    <changeSet id="1.0.6" author="nastya.kharchenko">
        <insert tableName="roles">
            <column name="name" value="ADMIN"></column>
        </insert>
    </changeSet>
</databaseChangeLog>